# Copy to .env (next to docker-compose.yml) and fill in. chmod 600 .env
# Create the OAuth client at https://login.tailscale.com/admin/settings/oauth
# with ONLY the "devices:read" (Devices -> Core -> Read) scope.
TS_OAUTH_CLIENT_ID=
TS_OAUTH_CLIENT_SECRET=
# Discord: Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=
# Optional: user to ping on CRITICAL/EXPIRED alerts. Must be the numeric
# Discord user ID in <@...> form (enable Developer Mode, right-click your
# profile -> Copy User ID). "@username" does not ping in webhooks.
DISCORD_MENTION=
